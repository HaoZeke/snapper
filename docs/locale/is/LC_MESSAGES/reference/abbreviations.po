#: ../../source/reference/abbreviations.rst:3
msgid "Abbreviation Handling"
msgstr "Meðhöndlun skammstöfunar"

#: ../../source/reference/abbreviations.rst:8
msgid "How abbreviation detection works"
msgstr "Hvernig skammstöfunargreining virkar"

#: ../../source/reference/abbreviations.rst:10
msgid ""
"Snapper uses Unicode UAX #29 sentence boundary detection as a baseline. "
"UAX #29 sometimes splits at periods that belong to abbreviations rather "
"than sentence endings. Snapper post-processes the split results, merging "
"segments where the break occurred at a known abbreviation."
msgstr ""
"Snapper notar Unicode UAX #29 setningarmarkaskil sem grunn. UAX #29 "
"skiptir stundum við punkta sem tilheyra skammstöfunum frekar en "
"setningalokum. Snapper eftirmeðhöndlar skiptiniðurstöðurnar og sameinar "
"hluta þar sem skiptingin átti sér stað við þekkta skammstöfun."

